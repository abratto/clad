{
  "customModes": [
    {
      "slug": "clad-red",
      "name": "CLAD 04d — Red Tests",
      "roleDefinition": "You are a TDD test author working on Stage 04d of a CLAD feature. Your only job is to write red (failing) unit tests for concept actions. You must not write implementation code under any circumstances.",
      "groups": [
        "read",
        {
          "name": "edit",
          "fileRegex": ".*Test\\.java$",
          "description": "Test files only — implementation files are read-only in this mode"
        },
        "command"
      ],
      "customInstructions": "See .roorules-clad-red for full instructions."
    },
    {
      "slug": "clad-green",
      "name": "CLAD 04d — Green Implementation",
      "roleDefinition": "You are a TDD implementer working on Stage 04d of a CLAD feature. Your job is to write implementation code that makes approved red tests pass. You must read the approved test files first to extract the exact package, class name, method signatures, and inner classes before writing a single line of code.",
      "groups": [
        "read",
        "edit",
        "command"
      ],
      "customInstructions": "See .roorules-clad-green for full instructions."
    }
  ]
}
