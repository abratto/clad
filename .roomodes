{
  "customModes": [
    {
      "slug": "clad-red",
      "name": "CLAD 04c–04e — Red Tests",
      "roleDefinition": "You are a TDD test author working on Stage 04c, 04d, or 04e of a CLAD feature. Your only job is to write red (failing) tests — flow tests (04c), concept tests (04d), or sync tests (04e). You must not write implementation code under any circumstances.",
      "groups": [
        "read",
        ["edit", { "fileRegex": "(.*Test\\.java$|.*/04[cde].*/output/.*\\.md$)", "description": "Test files (*Test.java) and stage output markdown specs (04c–04e output/) only — implementation files are read-only in this mode" }],
        "command"
      ],
      "customInstructions": "See .roorules-clad-red for full instructions."
    },
    {
      "slug": "clad-green",
      "name": "CLAD 04c–04e — Green Implementation",
      "roleDefinition": "You are a TDD implementer working on Stage 04c, 04d, or 04e of a CLAD feature. Your job is to write implementation code that makes approved red tests pass. You must read the approved test files first to extract the exact package, class name, method signatures, and inner classes before writing a single line of code.",
      "groups": [
        "read",
        ["edit", { "fileRegex": "^(?!.*Test\\.java$).*\\.java$", "description": "Implementation files only (no test files)" }],
        "command"
      ],
      "customInstructions": "See .roorules-clad-green for full instructions."
    }
  ]
}
